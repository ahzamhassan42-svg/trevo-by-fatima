rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Orders Collection ─────────────────────────────────────────
    match /orders/{orderId} {

      // ✅ Anyone can READ orders (admin panel needs full list access)
      //    Safe because orders contain no personal customer data —
      //    only product names, quantities, and totals.
      allow read: if true;

      // ✅ Anyone can CREATE a new order (customers checking out)
      allow create: if request.resource.data.keys().hasAll(['orderId','orderNum','date','items','status'])
                    && request.resource.data.status == 'Pending'
                    && request.resource.data.items.size() > 0;

      // ✅ Allow status updates (admin panel cycles order statuses)
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['status'])
                    && request.resource.data.status in ['Pending','Confirmed','Shipped','Delivered'];

      // ✅ Allow deletes (admin panel can remove orders)
      allow delete: if true;
    }

  }
}
